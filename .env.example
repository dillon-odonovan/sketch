# Copy to .env and fill in. Never commit .env.

# Discord app id from https://discord.com/developers/applications
DISCORD_APP_ID=

# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Discord public key from https://discord.com/developers/applications
DISCORD_PUBLIC_KEY=

# Optional: Discord server (guild) ID for instant slash-command sync during dev.
# Leave blank for global registration (~1 hour propagation).
DISCORD_GUILD_ID=

# Full service account JSON, on a single line. Example:
#   GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...", ...}
GOOGLE_CREDENTIALS_JSON=

# Google Sheets spreadsheet ID. Point this at a *test copy* during development.
SPREADSHEET_ID=
