# Copy to .env and fill in. Never commit .env.

# Discord app id from https://discord.com/developers/applications
DISCORD_APP_ID=

# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Discord public key from https://discord.com/developers/applications
DISCORD_PUBLIC_KEY=

# Optional: Discord server (guild) ID for instant slash-command sync during dev.
# Leave blank for global registration (~1 hour propagation).
DISCORD_GUILD_ID=

# Google credentials are resolved via Application Default Credentials (ADC):
#   - Easiest local setup: `gcloud auth application-default login` (one-time).
#   - Or set GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa-key.json if
#     you'd rather use a downloaded service-account JSON file.
#   - In production on GCE, the VM's attached service account is used
#     automatically via the metadata server — nothing to configure here.

# Google Sheets spreadsheet ID. Point this at a *test copy* during development.
SPREADSHEET_ID=

# Anthropic API key. Used by `/replica` to OCR Pokemon Champions share-screen
# screenshots into a structured team. Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Optional: override the vision model used for Replica OCR. Defaults to
# claude-opus-4-8 (chosen for multilingual share-screen accuracy). Set to e.g.
# claude-sonnet-4-6 to cut cost, or pin a specific model snapshot.
REPLICA_OCR_MODEL=
