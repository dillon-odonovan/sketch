# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
project_id   = "your-gcp-project-id"
github_owner = "dillon-odonovan"
github_repo  = "sketch"

# Per-guild routing (spreadsheet_id, broadcast_channel_id) lives in Firestore,
# not Terraform — Terraform only provisions the empty database. Add or update
# a guild with bin/seed_guilds.py (see README). The future /register-guild
# slash command writes to the same collection at runtime.

# Optional — uncomment to override defaults.
# region        = "us-west1"
# zone          = "us-west1-a"
# dev_guild_id  = "1234567890"
# image_tag     = "current"
