# Copied to /etc/sketch/env on the VM (chmod 600, owned by root:sketch).
# These are NON-secret configuration values; actual secrets live in Secret
# Manager and are pulled by launch.sh.

# Discord guild (server) ID where slash commands should be registered for
# instant sync. Omit or leave blank to register globally (~1 hour propagation).
DISCORD_GUILD_ID=

# Google Sheets spreadsheet ID. The bot's service account must have Editor
# access on this sheet.
SPREADSHEET_ID=

# Optional overrides if your secrets are named differently in Secret Manager.
# Defaults: sketch-discord-token and sketch-google-credentials-json.
# SKETCH_SECRET_DISCORD_TOKEN=
# SKETCH_SECRET_GOOGLE_CREDS=
