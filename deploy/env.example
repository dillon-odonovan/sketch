# Copied to /etc/sketch/env on the VM (chmod 640, owned by root:sketch).
# These are NON-secret configuration values; the Discord token lives in Secret
# Manager and is pulled by launch.sh. Google auth uses the VM's attached
# service account via Application Default Credentials — no JSON key needed.

# DEV ONLY: Discord guild (server) ID for instant slash-command sync during
# development. When set, slash commands are registered against just this guild
# (~5s). Leave blank in production for global registration (~1h propagation).
# This is independent of GUILD_CONFIG_JSON — DEV_GUILD_ID controls where
# slash commands are registered for fast iteration; GUILD_CONFIG_JSON controls
# which guilds the bot actually serves at runtime.
DEV_GUILD_ID=

# Per-guild routing. JSON object keyed by Discord guild_id (numeric string).
# Each value is an object with at least `spreadsheet_id`. The bot's service
# account must have Editor access on every spreadsheet listed. The bot refuses
# commands from any guild not present here.
# Example (single line; single-quote to survive shell):
#   GUILD_CONFIG_JSON='{"123456789012345678":{"spreadsheet_id":"1AbCd..."},"987654321098765432":{"spreadsheet_id":"1XyZw..."}}'
GUILD_CONFIG_JSON=

# Optional override if your Discord token secret is named differently in
# Secret Manager. Default: sketch-discord-token.
# SKETCH_SECRET_DISCORD_TOKEN=
